# ═══════════════════════════════════════════════════════════════
# OX GYM — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ═══════════════════════════════════════════════════════════════

# ── SUPABASE ──────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API

# Public URL — safe to expose in browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Public anon key — safe to expose in browser (RLS enforced)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Service role key — SERVER ONLY. Never expose to browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ── RESEND (email) ────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...

# The "from" address for all outgoing emails.
# Must be a verified domain in your Resend account.
EMAIL_FROM=noreply@yourgym.com

# ── APP ───────────────────────────────────────────────────────
# Full URL of your deployed app (no trailing slash)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ── CRON SECURITY ────────────────────────────────────────────
# A random secret string to authenticate cron job requests.
# Generate with: openssl rand -base64 32
# Set this same value in Vercel dashboard → Environment Variables
CRON_SECRET=your-random-secret-here

# ── ADMIN ALERTS ──────────────────────────────────────────────
# Email that receives an alert when cron email retries are exhausted.
# If unset, failed-reminder alerts are silently dropped.
ADMIN_ALERT_EMAIL=owner@yourgym.com
